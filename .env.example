# GitHub
GITHUB_TOKEN=ghp_your_token_here

# LLM
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=sk-your_openai_key_here

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=archaeologai
POSTGRES_USER=archaeologai
POSTGRES_PASSWORD=archaeologai_secret
DATABASE_URL=postgresql+asyncpg://archaeologai:archaeologai_secret@postgres:5432/archaeologai

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# App
APP_ENV=development
LOG_LEVEL=INFO
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_PROVIDER=gemini
